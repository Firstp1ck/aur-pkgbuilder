# Generated by Cargo
# will have compiled files and executables
debug/
target/
/target

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# VCS side-channels
.jj

# Editors / IDEs
.vscode/
.cache/
.*cache/

# Windows shortcuts
*.lnk

# Runtime logs from builds or the app itself
*/logs/*

# Output of dev/scripts/*
dev/scripts/Modules/*
clippy_errors.txt

# Python bytecode (from occasional helper scripts)
*.pyc
__pycache__/

# Per-branch scratch spaces used by the .cursor/commands/ workflows
dev/COMMIT/*
dev/PR/*

# Output of security audits run locally (see dev/scripts/security-check.sh)
dev/SECURITY_AUDIT_REPORT.md

# Security: prevent accidental secret commits
.env
.env.*
*.pem
*.key
credentials.json
service-account.json
